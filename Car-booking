<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Luxury Car Booking</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    body {
      font-family: 'Segoe UI', sans-serif;
      background-color: #f8f9fa;
    }
    .hero {
      background: url('https://picsum.photos/1600/600?car') center/cover no-repeat;
      color: white;
      text-align: center;
      padding: 120px 20px;
    }
    .hero h1 {
      font-size: 3rem;
      font-weight: bold;
    }
    .service-card {
      border: none;
      transition: transform 0.3s;
    }
    .service-card:hover {
      transform: translateY(-10px);
    }
    .navbar {
      background-color: #111;
    }
    .navbar-brand, .nav-link {
      color: #f8f9fa !important;
      font-weight: 500;
    }
    footer {
      background: #111;
      color: #aaa;
      padding: 30px;
      text-align: center;
    }
  </style>
</head>
<body>

<!-- Navbar -->
<nav class="navbar navbar-expand-lg">
  <div class="container">
    <a class="navbar-brand fw-bold" href="#">🚖 LuxuryCar</a>
    <button class="navbar-toggler" data-bs-toggle="collapse" data-bs-target="#menu">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="menu">
      <ul class="navbar-nav ms-auto">
        <li class="nav-item"><a class="nav-link" href="#booking">จองรถ</a></li>
        <li class="nav-item"><a class="nav-link" href="#services">บริการ</a></li>
        <li class="nav-item"><a class="nav-link" href="#contact">ติดต่อ</a></li>
      </ul>
    </div>
  </div>
</nav>

<!-- Hero Section -->
<section class="hero">
  <h1>บริการรถหรูหรา & น่าเชื่อถือ</h1>
  <p>จองรถแท็กซี่ รถตู้ รถเช่า พร้อมคนขับ ง่ายเพียงไม่กี่คลิก</p>
  <a href="#booking" class="btn btn-warning btn-lg mt-3">จองเลย</a>
</section>

<!-- Booking Form -->
<section id="booking" class="container py-5">
  <h2 class="text-center mb-4">แบบฟอร์มจองรถ</h2>
  <div class="card shadow p-4">
    <form>
      <div class="row g-3">
        <div class="col-md-6">
          <label class="form-label">ประเภทรถ</label>
          <select class="form-select">
            <option>แท็กซี่</option>
            <option>รถตู้</option>
            <option>รถเช่าพร้อมคนขับ</option>
            <option>ทัวร์ส่วนตัว</option>
          </select>
        </div>
        <div class="col-md-6">
          <label class="form-label">จำนวนผู้โดยสาร</label>
          <input type="number" class="form-control" placeholder="เช่น 4">
        </div>
        <div class="col-md-6">
          <label class="form-label">วันที่เริ่ม</label>
          <input type="date" class="form-control">
        </div>
        <div class="col-md-6">
          <label class="form-label">วันที่สิ้นสุด</label>
          <input type="date" class="form-control">
        </div>
        <div class="col-md-6">
          <label class="form-label">สถานที่รับ</label>
          <input type="text" class="form-control" placeholder="สนามบินสุวรรณภูมิ">
        </div>
        <div class="col-md-6">
          <label class="form-label">สถานที่ส่ง</label>
          <input type="text" class="form-control" placeholder="โรงแรมในพัทยา">
        </div>
      </div>
      <button type="submit" class="btn btn-dark mt-4 w-100">คำนวณราคา & จอง</button>
    </form>
  </div>
</section>

<!-- Services -->
<section id="services" class="container py-5">
  <h2 class="text-center mb-4">บริการของเรา</h2>
  <div class="row g-4">
    <div class="col-md-3">
      <div class="card service-card shadow">
        <img src="https://picsum.photos/400/200?1" class="card-img-top">
        <div class="card-body text-center">
          <h5>Taxi</h5>
          <p>สะดวก รวดเร็ว ราคาย่อมเยา</p>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card service-card shadow">
        <img src="https://picsum.photos/400/200?2" class="card-img-top">
        <div class="card-body text-center">
          <h5>Van</h5>
          <p>เหมาะกับกลุ่มใหญ่ นั่งสบาย</p>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card service-card shadow">
        <img src="https://picsum.photos/400/200?3" class="card-img-top">
        <div class="card-body text-center">
          <h5>Luxury Car</h5>
          <p>รถหรูพร้อมคนขับมืออาชีพ</p>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card service-card shadow">
        <img src="https://picsum.photos/400/200?4" class="card-img-top">
        <div class="card-body text-center">
          <h5>Tour Package</h5>
          <p>ทัวร์ส่วนตัว อิสระ ปลอดภัย</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Contact -->
<section id="contact" class="container py-5">
  <h2 class="text-center mb-4">ติดต่อเรา</h2>
  <div class="text-center">
    <p>📞 โทร: 080-123-4567</p>
    <p>💬 LINE: @luxurycar</p>
    <p>✉️ Email: booking@luxurycar.com</p>
  </div>
</section>

<!-- Footer -->
<footer>
  <p>© 2025 LuxuryCar Booking | Designed for premium experience</p>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
